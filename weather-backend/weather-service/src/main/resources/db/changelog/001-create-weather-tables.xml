<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="001" author="ile">
        <createTable tableName="weather_location">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="country" type="VARCHAR(100)"/>
            <column name="country_code" type="CHAR(2)"/>
            <column name="timezone" type="VARCHAR(100)"/>
            <column name="population" type="BIGINT"/>
            <column name="latitude" type="DECIMAL(9,6)">
                <constraints nullable="false"/>
            </column>
            <column name="longitude" type="DECIMAL(9,6)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="NOW()"/>
        </createTable>

        <createTable tableName="weather_current">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="location_id" type="UUID">
                <constraints nullable="false"
                    foreignKeyName="fk_weather_current_location"
                    references="weather_location(id)"/>
            </column>
            
            <column name="temperature" type="DECIMAL(5,2)">
                <constraints nullable="false"/>
            </column>
            <column name="apparent_temperature" type="DECIMAL(5,2)"/>
            <column name="relative_humidity" type="INTEGER"/>
            <column name="precipitation" type="DECIMAL(5,2)"/>
            <column name="wind_speed" type="DECIMAL(5,2)"/>
            <column name="wind_direction" type="INTEGER"/>
            <column name="surface_pressure" type="DECIMAL(7,2)"/>
            <column name="cloud_cover" type="INTEGER"/>

            <column name="weather_code" type="INTEGER"/>
            <column name="is_day" type="BOOLEAN"/>

            <column name="recorded_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="NOW()"/>
        </createTable>

        <createTable tableName="weather_forecast">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="location_id" type="UUID">
                <constraints nullable="false"
                    foreignKeyName="fk_weather_forecast_location"
                    references="weather_location(id)"/>
            </column>

            <column name="forecast_time" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="temperature" type="DECIMAL(5,2)"/>
            <column name="apparent_temperature" type="DECIMAL(5,2)"/>
            <column name="precipitation_probability" type="INTEGER"/>
            <column name="precipitation" type="DECIMAL(5,2)"/>
            <column name="wind_speed" type="DECIMAL(5,2)"/>
            <column name="wind_direction" type="INTEGER"/>
            <column name="weather_code" type="INTEGER"/>
            <column name="cloud_cover" type="INTEGER"/>
            <column name="relative_humidity" type="INTEGER"/>
            <column name="is_day" type="BOOLEAN"/>

            <column name="created_at" type="TIMESTAMP" defaultValueComputed="NOW()"/>
        </createTable>

        <createIndex tableName="weather_current"
                     indexName="idx_weather_current_location_recorded">
            <column name="location_id"/>
            <column name="recorded_at" descending="true"/>
        </createIndex>

        <createIndex tableName="weather_forecast"
                     indexName="idx_weather_forecast_location_time">
            <column name="location_id"/>
            <column name="forecast_time"/>
        </createIndex>

        <createIndex tableName="weather_location"
                     indexName="idx_weather_location_name">
            <column name="name"/>
        </createIndex>

        <createIndex tableName="weather_location"
                     indexName="idx_weather_location_coords">
            <column name="latitude"/>
            <column name="longitude"/>
        </createIndex>

    </changeSet>

</databaseChangeLog>
